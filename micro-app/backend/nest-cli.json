{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "assets/**/*",
        "outDir": "dist/src"
      },
      {
        "include": "ahorros/cuenta-ahorro/templates/**/*.docx",
        "outDir": "dist/src"
      }
    ],
    "watchAssets": true
  }
}
